# pnpm 11 runs an implicit dep-verification install before `pnpm <script>`, which
# fails here on sharp's un-approved native build script. We don't need sharp for
# the dashboard, so skip the pre-run check and just run the script directly.
verify-deps-before-run=false
# Don't auto-run dependency build scripts (sharp) — avoids network/native builds.
strict-dep-builds=false
