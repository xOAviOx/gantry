{
  "admin": {
    "listen": "0.0.0.0:2019",
    "origins": [
      "127.0.0.1:2019",
      "localhost:2019"
    ]
  },
  "logging": {
    "logs": {
      "default": {
        "level": "INFO"
      }
    }
  },
  "apps": {
    "http": {
      "servers": {
        "gantry": {
          "listen": [
            ":80"
          ],
          "routes": [
            {
              "match": [
                {
                  "host": [
                    "paas.localhost"
                  ]
                }
              ],
              "handle": [
                {
                  "handler": "subroute",
                  "routes": [
                    {
                      "match": [
                        {
                          "path": [
                            "/api/*",
                            "/webhooks/*"
                          ]
                        }
                      ],
                      "handle": [
                        {
                          "handler": "reverse_proxy",
                          "upstreams": [
                            {
                              "dial": "host.docker.internal:8080"
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "handle": [
                        {
                          "handler": "reverse_proxy",
                          "upstreams": [
                            {
                              "dial": "host.docker.internal:3000"
                            }
                          ]
                        }
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "match": [
                {
                  "host": [
                    "hello.apps.localhost"
                  ]
                }
              ],
              "handle": [
                {
                  "handler": "reverse_proxy",
                  "upstreams": [
                    {
                      "dial": "gantry-hello-abcd1234:3000"
                    }
                  ]
                }
              ]
            },
            {
              "match": [
                {
                  "host": [
                    "blog.apps.localhost"
                  ]
                }
              ],
              "handle": [
                {
                  "handler": "reverse_proxy",
                  "upstreams": [
                    {
                      "dial": "gantry-blog-9f8e7d6c:8000"
                    }
                  ]
                }
              ]
            }
          ]
        }
      }
    }
  }
}