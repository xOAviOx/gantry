# ── Gantry environment ────────────────────────────────────────────────────────
# Copy to deploy/.env and fill in the secrets. `make dev` / compose read this.

# Postgres (compose service)
POSTGRES_USER=gantry
POSTGRES_PASSWORD=gantry_dev_pw
POSTGRES_DB=gantry

# controld → Postgres (host process connects via the published 127.0.0.1:5432)
DATABASE_URL=postgres://gantry:gantry_dev_pw@127.0.0.1:5432/gantry?sslmode=disable

# controld HTTP listener. Caddy proxies here via host.docker.internal:8080.
CONTROLD_ADDR=:8080

# Next.js dev server. Caddy proxies here via host.docker.internal:3000.
WEB_ADDR=:3000

# Public HTTP port Caddy publishes on the host (change if 80 is taken).
GANTRY_HTTP_PORT=80

# Caddy admin API. controld renders the full config and POSTs it to /load here.
CADDY_ADMIN=http://127.0.0.1:2019

# Hostname Caddy (inside the container) uses to reach the host processes.
GANTRY_HOST_INTERNAL=host.docker.internal

# Docker Engine endpoint. Empty = Go SDK default (Windows named pipe), which
# works with Docker Desktop (verified). Uncomment to override.
# DOCKER_HOST=npipe:////./pipe/docker_engine

# Docker network that app containers join (created by compose).
GANTRY_APPS_NETWORK=gantry-apps

# Admin auth: Bearer token for the API and dashboard login.
ADMIN_TOKEN=change-me-admin-token

# GitHub webhook HMAC secret (used from M3).
GITHUB_WEBHOOK_SECRET=change-me-webhook-secret

# AES-256 master key for env-var encryption: base64 of exactly 32 random bytes.
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
#   openssl rand -base64 32
GANTRY_MASTER_KEY=REPLACE_WITH_BASE64_32_BYTES

# Queue / build tuning
GANTRY_WORKERS=2
GANTRY_BUILD_TIMEOUT=15m
# Queue hardening cadences (M3). Defaults match SPEC.md §7; override to speed up
# tests/demos.
# GANTRY_REAPER_INTERVAL=30s   # how often the reaper sweeps stale jobs
# GANTRY_JOB_STALE=60s         # a running job older than this (no heartbeat) is reaped
# GANTRY_HEARTBEAT=15s         # worker lock-refresh cadence
# GANTRY_LOCK_RETRY_DELAY=10s  # requeue delay when a project's deploy lock is busy
# GANTRY_CANCEL_POLL=2s        # how often a running build checks its cancel flag
# GANTRY_RECONCILE_INTERVAL=30s # how often the reconciler heals Docker/Caddy drift (M5)

# GC / disk lifecycle (M6)
GANTRY_KEEP_IMAGES=3              # images kept per project (last N deploys + live)
GANTRY_BUILDER_KEEP_STORAGE=20GB # BuildKit cache reserved space (prune keeps up to this)
# GANTRY_GC_INTERVAL=24h         # how often the scheduled GC runs
# GANTRY_LOG_RETENTION=336h      # delete log_lines older than this (14d)
